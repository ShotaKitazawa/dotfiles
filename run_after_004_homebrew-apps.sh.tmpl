#!/usr/bin/env bash

echo "### run_after_003_homebrew-apps.sh.tmpl ###"

{{ if eq .chezmoi.os "darwin" -}}

# install packages
# --no-upgrade: don't let `chezmoi apply` fight with casks that self-update (e.g. google-chrome)
brew bundle --no-upgrade --file=/dev/stdin << EOF
{{ template "Brewfile.apps" . }}
EOF

# exclude from `brew upgrade` (updates disrupt the active input method)
brew pin --cask google-japanese-ime

{{- end -}}

