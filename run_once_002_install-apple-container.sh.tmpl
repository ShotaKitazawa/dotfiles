#!/usr/bin/env bash

echo "### run_once_002_install-apple-container.sh.tmpl ###"

{{ if eq .chezmoi.os "darwin" -}}

VERSION="1.1.0"
PKG="/tmp/container-${VERSION}-installer-signed.pkg"

curl -fsSL "https://github.com/apple/container/releases/download/${VERSION}/container-${VERSION}-installer-signed.pkg" -o "$PKG"
sudo installer -pkg "$PKG" -target /
rm -f "$PKG"

launchctl load ~/Library/LaunchAgents/com.apple.container.autostart.plist

MOCKER_VERSION="v0.7.2"
mkdir -p ~/bin
curl -fsSL "https://github.com/us/mocker/releases/download/${MOCKER_VERSION}/mocker-${MOCKER_VERSION}-arm64-apple-macosx.tar.gz" \
  | tar -xz -C ~/bin mocker

{{- end }}
